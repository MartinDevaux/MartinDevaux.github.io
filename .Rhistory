library(tidyverse)
library(readxl)
rm(list = ls())
setwd('/Users/martindevaux/Dropbox/Research projects/immigrant entrepreneurship')
set.seed(2026)
sampling_frame <- readRDS('1_data/3_final_data/final_sampling_frame.rds')
# Create the strata
strat_sampling_frame <- sampling_frame |>
mutate(group = case_when(
citizenship == "France" ~ "French",
citizenship != "France" & !is.na(citizenship) ~ "Foreign",
TRUE ~ "Missing"
)) |>
nest(data = -c(gender, group))
n_groups <- nrow(strat_sampling_frame)
# First 100
approx_n_pilot <- 100
n_pilot <- approx_n_pilot + n_groups - (approx_n_pilot %% n_groups)
sample_pilot <- strat_sampling_frame |>
mutate(sample = map(.x = data,
~.x[sample(nrow(.x), n_pilot/n_groups, replace = FALSE),])) |>
select(sample, gender, group) |>
unnest(sample)
sample_pilot |> select(contact_id) |> write_csv('1_data/3_final_data/random_samples/sample_pilot.csv')
sampled_so_far <- sample_pilot$contact_id
# Wave 1
approx_n_wave_1 <- 1000
n_wave_1 <- approx_n_wave_1 + n_groups - (approx_n_wave_1 %% n_groups)
sample_wave_1 <- strat_sampling_frame |>
mutate(data = map(.x = data, ~.x |> filter(!contact_id %in% sampled_so_far))) |>
mutate(sample = map(.x = data,
~.x[sample(nrow(.x), n_wave_1/n_groups, replace = FALSE),])) |>
select(sample, gender, group) |>
unnest(sample)
sample_wave_1 |> select(contact_id) |> write_csv('1_data/3_final_data/random_samples/sample_wave_1.csv')
sampled_so_far <- c(sampled_so_far, sample_wave_1$contact_id)
# Wave 2
approx_n_wave_2 <- 1000
n_wave_2 <- approx_n_wave_2 + n_groups - (approx_n_wave_2 %% n_groups)
sample_wave_2 <- strat_sampling_frame |>
mutate(data = map(.x = data, ~.x |> filter(!contact_id %in% sampled_so_far))) |>
mutate(sample = map(.x = data,
~.x[sample(nrow(.x), n_wave_2/n_groups, replace = FALSE),])) |>
select(sample, gender, group) |>
unnest(sample)
sample_wave_2 |> select(contact_id) |> write_csv('1_data/3_final_data/random_samples/sample_wave_2.csv')
sampled_so_far <- c(sampled_so_far, sample_wave_2$contact_id)
# Wave 2
approx_n_wave_3 <- 1000
n_wave_3 <- approx_n_wave_3 + n_groups - (approx_n_wave_3 %% n_groups)
sample_wave_3 <- strat_sampling_frame |>
mutate(data = map(.x = data, ~.x |> filter(!contact_id %in% sampled_so_far))) |>
mutate(sample = map(.x = data,
~.x[sample(nrow(.x), n_wave_3/n_groups, replace = FALSE),])) |>
select(sample, gender, group) |>
unnest(sample)
sample_wave_3 |> select(contact_id) |> write_csv('1_data/3_final_data/random_samples/sample_wave_3.csv')
sampled_so_far <- c(sampled_so_far, sample_wave_3$contact_id)
